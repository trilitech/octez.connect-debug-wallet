{
  "name": "octez.connect-debug-wallet",
  "version": "0.0.0",
  "scripts": {
    "actions:deploy": "ng deploy --name $GITHUB_ACTOR --email $GITHUB_ACTOR@users.noreply.github.com --no-silent",
    "actions:prettier": "prettier \"src/**/*.ts\" \"e2e/**/*.ts\" \"angular.json\" \"README.md\" --list-different",
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "clean": "rm -rf dist",
    "build:prod": "ng build --configuration production",
    "rebuild:prod": "npm run clean && npm run build:prod",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "fix-crypto": "node config/patch_crypto.js && npm run prepare-prod-build",
    "prepare-prod-build": "npm run disable-pure-getters && npm run configure-mangle",
    "disable-pure-getters": "replace 'pure_getters: buildOptions.buildOptimizer' 'pure_getters: false' ./node_modules/@angular-devkit/build-angular/src/webpack/configs/common.js ",
    "configure-mangle": "replace 'safari10: true' 'safari10: true, keep_fnames: true' ./node_modules/@angular-devkit/build-angular/src/webpack/configs/common.js "
  },
  "private": true,
  "browser": {
    "fs": false,
    "vm": "vm-browserify"
  },
  "dependencies": {
    "@angular/animations": "^21.1.5",
    "@angular/common": "^21.1.5",
    "@angular/compiler": "^21.1.5",
    "@angular/core": "^21.1.5",
    "@angular/forms": "^21.1.5",
    "@angular/platform-browser": "^21.1.5",
    "@angular/platform-browser-dynamic": "^21.1.5",
    "@angular/router": "^21.1.5",
    "@taquito/rpc": "24.2.0",
    "@tezos-x/octez.connect-core": "1.0.0",
    "@tezos-x/octez.connect-dapp": "1.0.0",
    "@tezos-x/octez.connect-types": "1.0.0",
    "@tezos-x/octez.connect-wallet": "1.0.0",
    "assert-polyfill": "*",
    "bootstrap": "^4.5.3",
    "bs58check": "^2.1.2",
    "buffer": "^5.7.1",
    "crypto-browserify": "^3.5.1",
    "https-browserify": "^1.0.0",
    "json-formatter-js": "^2.3.4",
    "ngx-bootstrap": "^21.0.1",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "rxjs": "^7.8.2",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "tslib": "^2.8.1",
    "url": "^0.11.4",
    "util": "^0.12.4",
    "vm-browserify": "^1.1.2",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^21.0.3",
    "@angular-devkit/build-angular": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.5",
    "@types/bs58check": "^2.1.0",
    "@types/jasmine": "^5.1.7",
    "@types/node": "^22.15.30",
    "angular-cli-ghpages": "^3.0.2",
    "jasmine-core": "^5.7.2",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "replace": "^1.2.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "ajv": "^8.18.0",
    "bn.js": "^5.2.3"
  }
}
